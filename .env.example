# ══════════════════════════════════════
# Application Laravel
# ══════════════════════════════════════
APP_NAME=SkillHub
APP_ENV=production

# APP_KEY à générer avec la commande : php artisan key:generate --show
APP_KEY=

APP_DEBUG=false
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

# ══════════════════════════════════════
# Logs
# ══════════════════════════════════════
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ══════════════════════════════════════
# MySQL
# ─────────────────────────────────────
# DB_HOST = "db" avec docker-compose racine ; "127.0.0.1" en local sans Docker.
# Les variables SPRING_DATASOURCE_* d'auth-server sont surtout définies dans docker-compose.yml.
# ══════════════════════════════════════
DB_CONNECTION=mysql
DB_HOST=db
DB_PORT=3306
DB_DATABASE=skillhub_db
DB_USERNAME=skillhub_user
DB_PASSWORD=change_me

# Variables utilisées par le container MySQL dans docker-compose
MYSQL_ROOT_PASSWORD=change_me
MYSQL_DATABASE=skillhub_db
MYSQL_USER=skillhub_user
MYSQL_PASSWORD=change_me

# ══════════════════════════════════════
# MongoDB
# ─────────────────────────────────────
# MONGODB_HOST doit être "mongodb" dans Docker
# et "127.0.0.1" en local sans Docker
# ══════════════════════════════════════
MONGODB_URI=mongodb://mongo_user:change_me@mongodb:27017/skillhub_logs?authSource=admin
MONGODB_HOST=mongodb
MONGODB_PORT=27017
MONGODB_DATABASE=skillhub_logs
MONGODB_USERNAME=mongo_user
MONGODB_PASSWORD=change_me
MONGODB_AUTH_DATABASE=admin

# ══════════════════════════════════════
# Auth-server (Spring) — chiffrement AES des mots de passe + JWT
# ══════════════════════════════════════
# Clé AES (≥ 32 caractères), identique en local et dans Docker pour auth-server.
APP_MASTER_KEY=

# ══════════════════════════════════════
# Laravel — URL publique de l’auth-server (navigateur / intégrations)
# ══════════════════════════════════════
AUTH_SERVER_URL=http://localhost:8080

# ══════════════════════════════════════
# JWT (partagé Laravel + auth-server)
# ══════════════════════════════════════
# Même secret HS256 (≥ 32 caractères). Ne jamais committer la valeur réelle.
JWT_SECRET=

# Claim "iss" : identique côté Laravel (JWT_ISSUER) et auth-server.
JWT_ISSUER=ec06-auth-server

# Tolérance d'horloge pour la validation JWT côté Laravel (secondes).
JWT_LEEWAY=5

JWT_EXPIRATION_MINUTES=15

# Origines navigateur autorisées à appeler auth-server (CORS). Virgule = séparateur.
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ══════════════════════════════════════
# Spring Boot (auth-server) — rappel hors Docker
# ══════════════════════════════════════
# Avec docker-compose, SPRING_DATASOURCE_* et JWT_* sont souvent surchargés
# dans docker-compose.yml. Pour un lancement local du JAR sans Compose :
# SPRING_DATASOURCE_URL=jdbc:mysql://127.0.0.1:3306/auth_db
# SPRING_DATASOURCE_USERNAME=skillhub_user
# SPRING_DATASOURCE_PASSWORD=change_me

# ══════════════════════════════════════
# Session / Cache / Queue
# ══════════════════════════════════════
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database

# ══════════════════════════════════════
# Memcached
# ══════════════════════════════════════
MEMCACHED_HOST=127.0.0.1

# ══════════════════════════════════════
# Redis
# ══════════════════════════════════════
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# ══════════════════════════════════════
# Mail
# ══════════════════════════════════════
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# ══════════════════════════════════════
# AWS
# ══════════════════════════════════════
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# ══════════════════════════════════════
# Vite
# ══════════════════════════════════════
VITE_APP_NAME="${APP_NAME}"
VITE_API_BASE_URL=http://localhost:8000

# Depuis le navigateur sur la machine hôte : API Laravel et auth-server exposés sur ces ports.
VITE_AUTH_API_BASE_URL=http://localhost:8080